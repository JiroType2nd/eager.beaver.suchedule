# Database（開発・本番とも Neon 推奨。個人開発は同一 DB で OK）
# Neon の場合はダッシュボードの Connection string（Pooled）をそのまま貼り付け（?sslmode=require 付き）
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth（ポートと一致させる。3000が使用中で3001で起動する場合は3001に変更）
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-random-secret-at-least-32-chars"

# Google OAuth (Calendar API)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Refresh token 暗号化 (32 bytes = 64 hex chars). GCP では Secret Manager から注入推奨。
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Cloud Tasks → sync-calendar 用（本番で worker URL を指定）
CLOUD_TASKS_SYNC_CALENDAR_URL=""

# Seed 用（任意）
SEED_TEAM_PUBLIC_ID="default-team"
